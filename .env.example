# Copy this file to `.env` and adjust values for your setup.
# All values here are safe defaults — no secrets ever go in this file.

# SQLite file relative to project root. `data/` is gitignored.
DATABASE_URL="file:./data/app.db"

# Google Gemini API key. Free tier is generous (thousands of req/day on
# gemini-2.5-flash) and requires no credit card. Get one at:
#   https://aistudio.google.com/apikey
# You can also paste the key into the app's Settings page instead of
# setting it here — env value wins if both are set.
# GEMINI_API_KEY=""
