# Copy this file to `.env` and adjust values for your setup.
# All values here are safe defaults — no secrets ever go in this file.

# SQLite file relative to project root. `data/` is gitignored.
DATABASE_URL="file:./data/app.db"

# Anthropic API key (not required until Phase 7+). You can also set it
# from the Settings page in the running app, which stores it in the DB.
# ANTHROPIC_API_KEY=""
